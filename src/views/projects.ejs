<%- include('partials/header') %>

<main>
    <h1><%= title %></h1>
    <ul>
        <% projects.forEach(project => { %>
            <li>
                <% 
                    // Format the date in a user-friendly way
                    const date = new Date(project.project_date);
                    const formattedDate = date.toLocaleDateString('en-US', { 
                        year: 'numeric', 
                        month: 'long', 
                        day: 'numeric' 
                    });
                %>
                <strong><%= formattedDate %>:</strong> <a href="/project/<%= project.project_id %>"><%= project.title %></a> (<a href="/organization/<%= project.organization_id %>"><%= project.organization_name %></a>)
            </li>
        <% }); %>
    </ul>
    <p><a href="/new-project">Add a New Service Project</a></p>
</main>

<%- include('partials/footer') %>
