<%- include('partials/header') %>
<main>
    <h1><%= title %></h1>

    <h2><%= categoryDetails.name %> Category</h2>
    <% if (user && user.role_name === 'admin') { %>
        <p><a href="/edit-category/<%= categoryDetails.category_id %>">Edit</a></p>
    <% } %>

    <h3>Service Projects</h3>
    <% if (projects.length === 0) { %>
        <p>No service projects associated with this category yet.</p>
    <% } else { %>
        <ul>
            <% projects.forEach(project => { %>
                <li>
                    <a href="/project/<%= project.project_id %>"><%= project.title %></a> 
                    (Sponsor: <a href="/organization/<%= project.organization_id %>"><%= project.organization_name %></a>)
                </li>
            <% }) %>
        </ul>
    <% } %>
</main>
<%- include('partials/footer') %>
